# ==============================================================================
# BORG BARE-METAL CONFIGURATION
# File: backup.borg.config
# ==============================================================================

# ------------------------------------------------------------------------------
# Storage Target Mode
# ------------------------------------------------------------------------------
# Choose between "ssh" (Hetzner Storage Box) or "local" (Mounted USB drive, etc.)
CONF_TARGET_MODE="ssh"
CONF_LOCAL_REPO_BASE="/mnt/backup_drive"

# ------------------------------------------------------------------------------
# Identity & Repository Settings (IP ADDRESS to REPOSITORY binding)
# ------------------------------------------------------------------------------
# Repositories MUST BE UNIQUE PER SERVER (solves identical hostname collisions)
# You can add as much IP addresses and their respectife repository names as you want here

myip=$(ip route get 1.1.1.1 | sed -n 's/.*src \([0-9.]\+\).*/\1/p')
case "$myip" in
	"x.x.x.x")   
			CONF_MACHINE_NAME="server_1_full" 
	;;
	"y.y.y.y")   
			CONF_MACHINE_NAME="server_2_full" 
	;;
	"z.z.z.z")
			CONF_MACHINE_NAME="server_3_full"
	;;
	*)
			CONF_MACHINE_NAME="server_unknown"
	;;
esac

# Whether or not to do and "apt-get upgrade" right after restore 
# (the restored backup might not have all the current security updates) 
CONF_AUTO_UPDATE_AFTER_RESTORE=true

# Exchange "YORUSERACCOUNTID" with your actual user account ID
CONF_REPO_BASE="ssh://YOURUSERACCOUNTID.your-storagebox.de:23/./_server-backup"
CONF_SSH_KEY="/root/.ssh/id_rsa_borg"

# Exchange "THISISMYPASSWORD" with your actual SSH password. 
# This password is only needed to connect to the strorage at install time
CONF_SSH_PASSWORD="THISISMYPASSWORD"


# ------------------------------------------------------------------------------
# Backup Parameters
# ------------------------------------------------------------------------------

# Exchange "THISISMYPASSWORD" with your actual Borg BACKUP password. 
# It is highly encouraged to use one. As this file is never written to the 
# storage box in clear-text, it's safe to store the passphrase here.
# And as this file never gets overwritten by an autoupdate, you can also
# use a different passhrase on every server's backup, if you like.
CONF_PASSPHRASE="THISISMYPASSWORD"

CONF_ARCHIVE_PREFIX="${CONF_MACHINE_NAME}-"
CONF_COMPRESSION="lz4" 

# Keep the latest backup for each of the last x days.
CONF_KEEP_DAILY=14

# Keep the latest backup for each of the last x weeks.
CONF_KEEP_WEEKLY=4

# Keep the latest backup for each of the last x months.
CONF_KEEP_MONTHLY=2


# Exclusion List 
# Applied to BOTH Borg Backup creation AND Rsync Live Restore
# Here you can also define further custom directories to be excluded.
# However, do not remove any of the default excludes as this would most certainly crash restore.
CONF_EXCLUDES=(
    --exclude '/boot/efi' 
    --exclude '/dev/*'
    --exclude '/proc/*'
    --exclude '/sys/*'
    --exclude '/tmp/*'
    --exclude '/run/*'
    --exclude '/mnt/*'
    --exclude '/media/*'
    --exclude '/lost+found'
    --exclude '/var/tmp/*'
    --exclude '/var/run/*'
    --exclude '/swapfile'
    --exclude '/swap.img'
    --exclude '/restore_stage' # Protects the staging area during sync
)

# Database Dump Settings
# Of course only relevant if mysql databases exist
CONF_DUMP_DB=true
CONF_DB_DUMP_DIR="/var/backups/mysql_dumps"

# Base Hetzner path. The script will append the machine name to create isolated repos.
if [ "$CONF_TARGET_MODE" = "local" ]; then
    CONF_REPO="${CONF_LOCAL_REPO_BASE}/${CONF_MACHINE_NAME}"
else
    CONF_REPO="${CONF_REPO_BASE}/${CONF_MACHINE_NAME}"
fi
